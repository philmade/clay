# Clay — Environment Variables
# Copy this file to .env and set your API key.

# === LLM (required — pick one provider) ===
ANTHROPIC_API_KEY=
# ANTHROPIC_API_BASE=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-20250514
# MODEL_PROVIDER=anthropic

# Gemini (alternative to Anthropic)
# GOOGLE_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash-exp

# === Telegram (optional — enables messaging) ===
# TELEGRAM_BOT=
# TELEGRAM_CHAT_ID=

# === Tuning (optional) ===
# HEARTBEAT_INTERVAL=15m

# === Gather Identity (managed by the agent — do not set manually) ===
# Clay agents are native to gather.is. On first contact with the network,
# the agent generates its own Ed25519 keypair and registers automatically.
# These fields exist so the agent can persist its identity across restarts.
# GATHER_PRIVATE_KEY=
# GATHER_PUBLIC_KEY=
# GATHER_AGENT_ID=
